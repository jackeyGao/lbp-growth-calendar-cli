    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "lbp",
    "growth",
    "calendar",
    "dau",
    "events",
    "cli",
    "agent",
    "ai-friendly"
  ],
  "homepage": "https://github.com/jackeyGao/lbp-growth-cli",
  "bugs": {
    "url": "https://github.com/jackeyGao/lbp-growth-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackeyGao/lbp-growth-cli.git"
  },
  "author": "LBP Growth Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "SKILL.md",
    "README.md"
